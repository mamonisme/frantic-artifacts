# Credential guard — NEVER commit secrets
.env
*.env
*.key
*.pem
id_rsa
id_ed25519
credentials*
secrets*
auth.json
*.token
wallet*
*_priv*

# scafld runtime state
# Keep project-owned specs/config/prompts in git; ignore generated core and local runtime state.
!.scafld/
!.scafld/config.yaml
!.scafld/prompts/
!.scafld/prompts/**
!.scafld/specs/
!.scafld/specs/**
!.scafld/trusted-keys.json
!.scafld/receipts/
.scafld/receipts/*
!.scafld/receipts/*.json
.scafld/config.local.yaml
.scafld/core/
.scafld/keys/
.scafld/private-keys/
.scafld/**/*.key
.scafld/**/*.pem
.scafld/prompts/.manifest.json
.scafld/runs/
